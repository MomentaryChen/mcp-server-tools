# ========== 選填：指定 .env 路徑（預設為執行目錄下的 .env） ==========
# ENV_FILE=.env

# ========== MySQL（必填） ==========
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=your_database
# 是否允許各類 MySQL 操作（true/false，預設 true）
# MYSQL_QUERY_OPERATION=true
# MYSQL_INSERT_OPERATION=true
# MYSQL_UPDATE_OPERATION=true
# MYSQL_DELETE_OPERATION=true

# ========== SSH 通道（選填；多層 jump server 格式） ==========
# 以 JSON 陣列描述每一層，順序為「由外到內」
# 每一層可使用 password 或 privateKeyPath / privateKey
# SSH_JUMPS=[{"host":"jump-1.example.com","port":22,"user":"ubuntu","privateKeyPath":"D:/keys/jump1"},{"host":"jump-2.internal","port":22,"user":"ec2-user","privateKeyPath":"D:/keys/jump2"}]
# 可為不同服務指定不同 jump chain（未指定時 fallback 到 SSH_JUMPS）
# MYSQL_SSH_JUMPS=[{"host":"mysql-jump.example.com","port":22,"user":"ubuntu","privateKeyPath":"D:/keys/mysql-jump"}]
# TDENGINE_SSH_JUMPS=[{"host":"jump-1.example.com","port":22,"user":"ubuntu","privateKeyPath":"D:/keys/jump1"},{"host":"jump-2.internal","port":22,"user":"ec2-user","privateKeyPath":"D:/keys/jump2"}]
# MONGO_SSH_JUMPS=[{"host":"mongo-jump.example.com","port":22,"user":"ubuntu","privateKeyPath":"D:/keys/mongo-jump"}]
# 啟用 SSH 時，MYSQL_HOST 會作為遠端 MySQL 目標位址

# ========== MongoDB（選填，用於 server-mongodb.js） ==========
# MONGO_HOST=127.0.0.1
# MONGO_PORT=27017
# MONGO_USER=your_user
# MONGO_PASSWORD=your_password
# MONGO_DATABASE=your_database
# MONGO_AUTH_SOURCE=your_auth_db  # 預設為 MONGO_DATABASE
# MONGO_AUTH_MECHANISM=SCRAM-SHA-256
# 是否允許各類 MongoDB 操作（true/false，預設 true）
# MONGO_QUERY_OPERATION=true
# MONGO_INSERT_OPERATION=true
# MONGO_UPDATE_OPERATION=true
# MONGO_DELETE_OPERATION=true
# MONGO_LIST_COLLECTIONS_OPERATION=true
# 若需經 SSH jump server 連 MongoDB，可搭配上方 SSH_JUMPS / MONGO_SSH_JUMPS 設定使用

# ========== TDengine REST API（選填，用於 server-tdengine.js） ==========
# TDENGINE_HOST=127.0.0.1
# TDENGINE_PORT=6041
# TDENGINE_USER=root
# TDENGINE_PASSWORD=taosdata
# 是否允許各類 TDengine 操作（true/false，預設 true）
# TDENGINE_QUERY_OPERATION=true
# TDENGINE_INSERT_OPERATION=true
# TDENGINE_UPDATE_OPERATION=true
# TDENGINE_DELETE_OPERATION=true
